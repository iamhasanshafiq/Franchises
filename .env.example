# URL of barqi-identity service (no trailing slash)
VITE_AUTH_URL=http://localhost:3000

# URL of barqi-franchise service API (no trailing slash, include /api prefix)
VITE_FRANCHISE_URL=http://localhost:3001/api

# Optional: wallet / media services
VITE_WALLET_URL=https://api.barqibazar.org/wallet
VITE_BASE_URL_FILE_UPLOAD=https://api.barqibazar.org/media/api

# Google Maps API key (used in store location views)
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key_here
